# Required: API key for the upstream LLM provider (e.g. Chutes)
CHUTES_API_KEY=your-api-key-here

# Optional: Override the upstream API base URL (default: https://llm.chutes.ai/v1)
# UPSTREAM_API_BASE=https://llm.chutes.ai/v1

# Optional: Separate API key for authenticating callers to the router
# If not set, CHUTES_API_KEY is used for both upstream calls and caller auth
# ROUTER_API_KEY=your-router-auth-key
